datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RoleStatus {
  SUPER_ADMIN
  FINANCE
  DAILY_ADMIN
  MARKETING_STAFF
  MARKETING_SEMENTARA
}

model Pegawai {
  id                 String               @id @default(cuid())
  nama               String
  nip                String?              @unique
  prefix             String?
  kode               String?
  jabatan            String?
  departemen         String?

  // Foto profil
  fotoUrl            String?
  fotoKey            String?              // key di storage (S3/R2/dll)

  // Dokumen (relasi ke model terpisah)
  dokumen            DokumenPegawai[]

  dailyActivities    DailyActivity[]
  hakAksesKaryawan   HakAksesKaryawan[]
  permohonanHakAkses PermohonanHakAkses[]
  pengajuanJudulTraining PengajuanJudulTraining[]
  jadwalDiupdate     JadwalTraining[]
  pesertaDiinput     PesertaTraining[]    @relation("PesertaInputOleh")
  pesertaDiupdate    PesertaTraining[]    @relation("PesertaUpdateOleh")
  pesertaDikonfirmasi PesertaTraining[]  @relation("PesertaKonfirmasiOleh")
  pengajuanIzin  PengajuanIzin[]
  user               User?
}

model DokumenPegawai {
  id         String   @id @default(cuid())
  pegawaiId  String
  nama       String                // nama file asli, misal "KTP.pdf"
  url        String                // URL akses file
  key        String                // key di storage untuk delete/update
  tipe       String?               // opsional: "KTP", "NPWP", "Ijazah", dll
  createdAt  DateTime @default(now())

  pegawai    Pegawai  @relation(fields: [pegawaiId], references: [id], onDelete: Cascade)
}

model User {
  id            String          @id @default(cuid())
  pegawaiId     String          @unique
  phone         String          @unique
  email         String          @unique
  password      String
  role          RoleStatus
  createdAt     DateTime        @default(now())
  devices       DeviceTrusted[]
  otps          OtpCode[]
  refreshTokens RefreshToken[] //

  pegawai Pegawai @relation(fields: [pegawaiId], references: [id])
}

model RefreshToken {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceHash String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
}

model DeviceTrusted {
  id         String   @id @default(cuid())
  userId     String
  deviceHash String // hash dari fingerprint device
  label      String? // misal: "Chrome - Windows"
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, deviceHash])
}

model OtpCode {
  id         String   @id @default(cuid())
  userId     String
  code       String
  deviceHash String
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now()) // ← tambah ini
  user       User     @relation(fields: [userId], references: [id])
}

model TabPerusahaan {
  // =========================
  // CORE + COMMON (SEMUA JENIS)
  // =========================
  noInduk       String  @id @map("0NO_INDUK") @db.VarChar(50)
  jenisInstansi String  @default("PERUSAHAAN") @db.VarChar(50)

  company       String? @map("1COMPANY") @db.VarChar(255)

  alamat        String? @map("2ALAMAT") @db.VarChar(255)
  telp          String? @map("5TELP") @db.VarChar(255)
  fax           String? @map("6FAX") @db.VarChar(255)
  email         String? @map("7EMAIL") @db.VarChar(255)
  ket           String? @map("24KET")
  fasilitas     String? @db.VarChar(255)
  butuhTraining String? @map("ButuhTraining") @db.VarChar(255)
  prioritasMa   String? @db.VarChar(50)
  prioritasAe   String? @db.VarChar(50)
  group         String? @map("21GROUP") @db.VarChar(255)
  akreditasi    String? @db.VarChar(50)

  // =========================
  // PERUSAHAAN + RUMAH_SAKIT
  // =========================
  idSimpel String? @db.VarChar(100)

  alamatWaktu        String? @db.VarChar(4)
  alamatFactory      String? @db.VarChar(255)
  alamatFactoryWaktu String? @db.VarChar(4)

  iso9000        String? @db.VarChar(255)
  iso14000       String? @db.VarChar(255)
  ohsas18001smk3 String? @db.VarChar(255)

  kategoriCpn    String? @db.VarChar(255)
  lineOfBusiness String? @db.VarChar(255)
  lineBisnisSub  String? @db.VarChar(255)
  permodalan     String? @db.VarChar(255)

  nilaiSubBidangProper Int?
  batasEmas            Int?
  batasHijau           Int?
  infoKeu              String? @db.VarChar(255)
  bdoAction            String? @db.VarChar(50)
  vendor               String? @db.VarChar(15)

  cabangSite        String? @db.VarChar(255)
  pesaing           String? @db.VarChar(255)
  prosedurPelatihan String? @db.VarChar(255)

  // =========================
  // PEMDA
  // =========================
  kotaKabupaten String? @db.VarChar(100)
  provinsi      String? @db.VarChar(100)
  instansi      String? @db.VarChar(255)
  sekilasLh     String? @db.Text

  rsud                Int? @default(0)
  indPengolahan       Int? @default(0)
  pertambangan        Int? @default(0)
  listrikGasAirBersih Int? @default(0)
  hotelResto          Int? @default(0)
  angkutTrans         Int? @default(0)
  bangunan            Int? @default(0)
  pertanian           Int? @default(0)
  keuangan            Int? @default(0)
  laut                Int? @default(0)
  jasa                Int? @default(0)

  // =========================
  // INSTANSI DAERAH
  // =========================
  kode String? @db.VarChar(100)

  tender1 String? @db.VarChar(255)
  tender2 String? @db.VarChar(255)
  tender3 String? @db.VarChar(255)

  pelatihanDiikuti String? @db.Text

  // =========================
  // SEKOLAH
  // =========================
  pemilik     String? @db.VarChar(255)
  yayasan     String? @db.VarChar(255)
  subKategori String? @db.VarChar(255)
  cpSekolah   String? @db.VarChar(255)

  inputter   String?
  updatter   String?
  dateInput  DateTime?
  dateUpdate DateTime?

  // =========================
  // RELATION
  // =========================
  contactPersons     ContactPersonPerusahaan[]
  dailyActivities    DailyActivity[]
  sertifikasiBnsp SertifikasiBnsp[]
  proper          Proper[]
  hakAksesKaryawan   HakAksesKaryawan[]
  logs               LogPerubahanPerusahaan[]
  posPerusahaan      TabPosPerusahaan[]
  permohonanHakAkses PermohonanHakAkses[]
  penawaran  Penawaran[]
  pengajuanJudulTraining PengajuanJudulTraining[]
  pesertaTraining PesertaTraining[]
}

model ContactPersonPerusahaan {
  kode            String  @id @default(cuid()) @map("KODE") @db.VarChar(50)
  kodePerusahaan  String  @map("KODE_PERUSAHAAN") @db.VarChar(50)
  nama            String  @map("NAMA") @db.VarChar(255)
  teknisTertinggi Boolean @default(false) @map("TEKNIS_TERTINGGI")
  jabatan         String? @map("JABATAN") @db.VarChar(255)
  hp              String? @map("HP") @db.VarChar(50)
  email           String? @map("EMAIL") @db.VarChar(255)
  posisi          String? @map("POSISI") @db.VarChar(50) // "Alamat Pusat" | "Alamat Factory"
  keuangan        String? @map("KEUANGAN") @db.VarChar(50) // "Penagihan" | "-"
  minta           String? @map("MINTA") @db.VarChar(255)
  ket             String? @map("KET") @db.Text

  // Relasi ke TabPerusahaan
  perusahaan TabPerusahaan @relation(fields: [kodePerusahaan], references: [noInduk], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([kodePerusahaan])
  @@map("contact_person_perusahaan")
}

model DailyActivity {
  id            String    @id @default(cuid()) @map("ID")
  pegawaiId     String    @map("PEGAWAI_ID") @db.VarChar(50) // Foreign key ke Pegawai
  perusahaanId  String    @map("PERUSAHAAN_ID") @db.VarChar(50) // Foreign key ke TabPerusahaan
  kontak        String    @map("KONTAK") @db.VarChar(255)
  jenisTraining String    @map("JENIS_TRAINING") @db.VarChar(255)
  keterangan    String    @map("KETERANGAN") @db.VarChar(255)
  kategori      String    @map("KATEGORI") @db.VarChar(255)
  inout         String    @map("INOUT") @db.VarChar(50)
  tanggal       String    @map("TANGGAL") @db.VarChar(50)
  dateTarget    DateTime? @map("DATE_TARGET") @db.Date
  perusahaan    String    @map("PERUSAHAAN") @db.VarChar(255)

  // Relasi ke Pegawai
  pegawai Pegawai @relation(fields: [pegawaiId], references: [id], onDelete: Cascade)

  // Relasi ke TabPerusahaan
  tabPerusahaan TabPerusahaan @relation(fields: [perusahaanId], references: [noInduk], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([perusahaanId])
  @@index([pegawaiId])
  @@map("daily_activity")
}

model HakAksesKaryawan {
  id            String   @id @default(cuid())
  perusahaanId  String
  pegawaiId     String? // Nullable
  jenisAkses    String
  status        String?
  tanggalDibuat DateTime @default(now())

  // Relasi
  perusahaan TabPerusahaan @relation(fields: [perusahaanId], references: [noInduk])
  pegawai    Pegawai?      @relation(fields: [pegawaiId], references: [id]) // Relasi optional
}

model LogPerubahanPerusahaan {
  id           String   @id @default(cuid())
  perusahaanId String   @map("perusahaan_id")
  field        String // Nama field yang diubah (misal: "alamat", "company", atau "HAK_AKSES")
  dataLama     Json?    @map("data_lama")
  dataBaru     Json?    @map("data_baru")
  diubahOleh   String   @map("diubah_oleh") // Nama atau ID user
  tanggal      DateTime @default(now())

  // Relasi ke TabPerusahaan (Optional, biar bisa ditarik dari sisi perusahaan)
  perusahaan TabPerusahaan @relation(fields: [perusahaanId], references: [noInduk], onDelete: Cascade)

  @@index([perusahaanId])
  @@map("log_perubahan_perusahaan")
}

model TabPosPerusahaan {
  id       String  @id @default(cuid())
  nama     String  @db.VarChar(255)
  jabatan  String  @db.VarChar(255)
  followUp String? @map("FOLLOW_UP") @db.VarChar(255)
  noInduk  String  @map("NO_INDUK") @db.VarChar(50)
  acc      String  @map("ACC") @db.VarChar(255)

  perusahaan TabPerusahaan @relation(fields: [noInduk], references: [noInduk])

  @@map("tabposperusahaan")
}

model Penawaran {
  id            String   @id @default(cuid())
  kodePelatihan String[]
  tanggal       DateTime @default(now())
  filePath      String?  @db.VarChar(500)

  perusahaanId  String
  perusahaan    TabPerusahaan @relation(fields: [perusahaanId], references: [noInduk])

  @@map("penawaran")
}

model PermohonanHakAkses {
  id           String   @id @default(cuid())
  perusahaanId String   @map("perusahaan_id")
  pegawaiId    String   @map("pegawai_id")
  jenisAkses   String   @map("jenis_akses") @db.VarChar(10)
  terima       Boolean?
  tanggal      DateTime @default(now())

  perusahaan TabPerusahaan @relation(fields: [perusahaanId], references: [noInduk])
  pegawai    Pegawai       @relation(fields: [pegawaiId], references: [id])

  @@map("permohonan_hak_akses")
}

model SertifikasiBnsp {
  id          Int     @id @default(autoincrement())
  perusahaanId String @db.VarChar(50)

  pppa    String? @db.VarChar(255)
  popal   String? @db.VarChar(255)
  pppu    String? @db.VarChar(255)
  poippu  String? @db.VarChar(255)
  limbahB3 String? @db.VarChar(255)
  tpsLb3  String? @db.VarChar(255)
  sampah3R String? @db.VarChar(255)
  pSampah  String? @db.VarChar(255)
  aEnergi  String? @db.VarChar(255)
  mEnergi  String? @db.VarChar(255)
  pcua    String? @db.VarChar(255)
  lca     String? @db.VarChar(255)

  perusahaan TabPerusahaan @relation(fields: [perusahaanId], references: [noInduk])
}

model Proper {
  id          Int     @id @default(autoincrement())
  perusahaanId String @db.VarChar(50)
  tahun       Int

  emas  Int @default(0)
  hijau Int @default(0)
  biru  Int @default(0)
  merah Int @default(0)
  hitam Int @default(0)

  perusahaan TabPerusahaan @relation(fields: [perusahaanId], references: [noInduk])
}

model Hotel {
  id        String  @id @default(cuid())

  kodeHotel String  @unique @map("kode_hotel") // PM
  namaHotel String  @map("nama_hotel")
  alamat    String
  kota      String
  telepon   String

  fax       String? // optional

  pubRate   Int?    @map("pub_rate") // optional integer
  corRate   Int?    @map("cor_rate") // optional integer

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("hotel")
}

model Trainer {
  id             Int      @id @default(autoincrement())
  kode           String   @unique
  nama           String
  referensi      String?
  alamat         String?
  subjekKhusus   String?
  telp           String?
  keterangan     String?
  email          String?
  tugas          DateTime?
  kantor         String?
  alamatKantor   String?
  noTelpKantor   String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  jadwalTraining TrainerOnJadwal[]

  @@map("kontak")
}

model PengajuanJudulTraining {
  id              String   @id @default(cuid())
  judulTraining   String
  jumlahHari      Int
  namaKontak      String?
  kontak          String?
  jumlahPeserta   Int?
  responMA  String?  @default("PENDING")
  tanggalPengajuan  DateTime @default(now())

  // Relasi ke TabPerusahaan
  perusahaanId    String
  perusahaan      TabPerusahaan @relation(fields: [perusahaanId], references: [noInduk])

  // Relasi ke Pegawai
  inputOlehId     String
  inputOleh       Pegawai  @relation(fields: [inputOlehId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("pengajuan_judul_training")
}

model JudulTraining {
  id            Int      @id @default(autoincrement())
  kode          String   @unique
  judulTraining String
  tipe          String
  hari          Int
  biayaOffline  Int
  biayaOnline   Int
  batch         Int
  brosur        String?  // path/url file brosur

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  jadwalTraining JadwalTraining[]

  @@map("judul_training")
}

model JadwalTraining {
  id            Int      @id @default(autoincrement())
  noJadwal      String   @unique
  kodePelatihan String
  tglMulai      DateTime?
  tglSelesai    DateTime?
  judulLengkap  String
  judulPendek   String
  metode        String
  kota          String
  lokasiDetail  String?
  biaya         Int
  jenisTraining String
  status        String
  catatan       String?
  fileAgenda    String?
  lastUpdate    DateTime  @updatedAt
  
  // Relations
  updateOleh    String
  pegawai       Pegawai   @relation(fields: [updateOleh], references: [id])

  judulTraining JudulTraining @relation(fields: [kodePelatihan], references: [kode])

  trainers      TrainerOnJadwal[]
  peserta PesertaTraining[]

  @@map("jadwal_training")
}

// Pivot table Trainer <-> JadwalTraining
model TrainerOnJadwal {
  jadwalId  Int
  trainerKode String

  jadwal    JadwalTraining @relation(fields: [jadwalId], references: [id])
  trainer   Trainer        @relation(fields: [trainerKode], references: [kode])

  @@id([jadwalId, trainerKode])
  @@map("trainer_on_jadwal")
}

model PesertaTraining {
  id                    Int       @id @default(autoincrement())

  // Data Peserta
  nama                  String
  jabatan               String?
  alamat                String?
  noTelp                String?
  noFax                 String?
  email                 String?
  alamatPengirimanSertifikat String?
  catatan               String?
  industri              String?
  status                String?
  ownEnv                String?
  metode                String?
  fileBuktiPembayaran   String?
  filePendaftaran       String?

  // Relasi ke TabPerusahaan
  noIndukPerusahaan     String
  perusahaan            TabPerusahaan @relation(fields: [noIndukPerusahaan], references: [noInduk])

  // Relasi ke JadwalTraining
  noJadwal              String
  jadwalTraining        JadwalTraining @relation(fields: [noJadwal], references: [noJadwal])

  // AE (Account Executive) - string
  accExecutive          String?

  // Ujian
  ujian                 String?  
  noInvUjian            String?
  noKwtUjian            String?

  // Keuangan
  diskon                Int?
  ppn                   Int?
  cashback              Int?
  hargaTotal            Int?
  bayar                 Int?
  infoPembayaran        String?
  infoPenagihan         String?
  tglBayar              DateTime?
  noInvoice             String?
  noKwitansi            String?

  // Relasi ke Pegawai
  inputOleh             String
  pegawaiInput          Pegawai   @relation("PesertaInputOleh", fields: [inputOleh], references: [id])

  updateOleh            String?
  pegawaiUpdate         Pegawai?  @relation("PesertaUpdateOleh", fields: [updateOleh], references: [id])

  konfirmasiOleh        String?
  pegawaiKonfirmasi     Pegawai?  @relation("PesertaKonfirmasiOleh", fields: [konfirmasiOleh], references: [id])

  // Timestamps
  tglInput              DateTime  @default(now())
  tglUpdate             DateTime  @updatedAt

  @@map("peserta_training")
}

enum JenisIzin {
  CUTI
  SAKIT
  IZIN
}

enum StatusIzin {
  PENDING
  DISETUJUI
  DITOLAK
}

model PengajuanIzin {
  id             String         @id @default(cuid())
  pegawaiId      String
  jenisIzin      JenisIzin
  tanggalMulai   DateTime
  tanggalSelesai DateTime
  alasan         String
  alasanTolak    String?
  tanggalKonfirmasi DateTime?
  status         StatusIzin     @default(PENDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  pegawai        Pegawai        @relation(fields: [pegawaiId], references: [id], onDelete: Cascade)
  bukti          BuktiIzin[]
}

model BuktiIzin {
  id              String        @id @default(cuid())
  pengajuanIzinId String
  nama            String
  url             String
  key             String
  createdAt       DateTime      @default(now())

  pengajuanIzin   PengajuanIzin @relation(fields: [pengajuanIzinId], references: [id], onDelete: Cascade)
}